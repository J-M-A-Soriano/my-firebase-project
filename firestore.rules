rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jcesperanza@neu.edu.ph' ||
        request.auth.token.email == 'johnmichaelsoriano76@gmail.com' ||
        request.auth.token.email == 'johnmichaelsoriano151@gmail.com' ||
        request.auth.token.email == 'admin@neu.edu.ph' ||
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
      );
    }

    match /admin_users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    match /students/{studentId} {
      // Allow the kiosk to verify if an ID exists or create a new profile
      allow get, create: if true;
      // Listing all students or updating/deleting requires admin authority
      allow list, update, delete: if isAdmin();
    }

    match /libraryVisits/{visitId} {
      // Allow any visitor to log their entry from the kiosk
      allow create: if true;
      // Only admins can view the operational logs or modify them
      allow read, update, delete: if isAdmin();
    }

    match /colleges/{collegeId} {
      // Allow public lookup for the registration dropdown
      allow read: if true;
    }

    match /reasonsForVisit/{reasonId} {
      allow read: if true;
    }
  }
}