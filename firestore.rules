rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - PROTOTYPE VERSION
     *
     * In this prototype, we relax the strict staff check to allow any 
     * authenticated user to interact with the system.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Relaxed for prototype development: any signed-in user is treated as staff
    function isLibraryStaff() {
      return isSignedIn();
    }

    function isExistingStaff() {
      return isLibraryStaff() && resource != null;
    }

    match /students/{studentId} {
      allow get, list: if isLibraryStaff();
      allow create: if isLibraryStaff();
      allow update: if isExistingStaff();
      allow delete: if isExistingStaff();
    }

    match /librarySessions/{sessionId} {
      allow get, list: if isLibraryStaff();
      allow create: if isLibraryStaff();
      allow update: if isExistingStaff();
      allow delete: if isExistingStaff();
    }

    match /roles_libraryStaff/{uid} {
      allow get: if isSignedIn();
      allow list: if isLibraryStaff();
      allow create, update, delete: if false;
    }
  }
}