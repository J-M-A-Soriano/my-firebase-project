
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Visitor Log - Security Rules
     * 
     * Fixed role paths to support even-segment document references.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    function isAdminAndResourceExists() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    match /colleges/{collegeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /reasonsForVisit/{reasonId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /students/{studentUniqueId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdminAndResourceExists();
    }

    match /staff/{staffUniqueId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdminAndResourceExists();
    }

    match /admin_users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /regular_users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /libraryVisits/{visitId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdminAndResourceExists();
    }

  }
}
