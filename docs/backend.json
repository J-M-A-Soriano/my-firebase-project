
{
  "entities": {
    "College": {
      "title": "College",
      "type": "object",
      "description": "Academic department metadata.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "ReasonForVisit": {
      "title": "ReasonForVisit",
      "type": "object",
      "description": "Visit categorization.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Student or Staff/Teacher profile data.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "collegeOrOffice": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "type": { "type": "string", "enum": ["Student", "Teacher", "Staff"] }
      },
      "required": ["id", "firstName", "lastName", "type"]
    },
    "LibraryVisit": {
      "title": "LibraryVisit",
      "type": "object",
      "description": "Transactional log of entry/exit.",
      "properties": {
        "id": { "type": "string" },
        "checkInTime": { "type": "string", "format": "date-time" },
        "checkOutTime": { "type": "string", "format": "date-time" },
        "visitorType": { "type": "string", "enum": ["Student", "Teacher", "Staff"] },
        "visitorId": { "type": "string" },
        "visitorName": { "type": "string" },
        "collegeOrOffice": { "type": "string" },
        "purpose": { "type": "string" }
      },
      "required": ["id", "checkInTime", "visitorType", "visitorId", "purpose"]
    },
    "AdminRole": {
      "title": "AdminRole",
      "type": "object",
      "description": "Administrative authority marker.",
      "properties": {}
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "admin_users/{userId}": {
      "schema": "#/entities/AdminRole",
      "description": "Authorized administrative accounts."
    },
    "students/{studentId}": {
      "schema": "#/entities/Student",
      "description": "Visitor profile registry."
    },
    "libraryVisits/{visitId}": {
      "schema": "#/entities/LibraryVisit",
      "description": "Live transaction logs."
    },
    "colleges/{collegeId}": {
      "schema": "#/entities/College",
      "description": "Academic unit references."
    },
    "reasonsForVisit/{reasonId}": {
      "schema": "#/entities/ReasonForVisit",
      "description": "Visit purpose references."
    }
  }
}
