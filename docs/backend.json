
{
  "entities": {
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Represents a library visitor (student, faculty, or employee).",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "collegeOrOffice": { "type": "string" },
        "isBlocked": { "type": "boolean", "default": false }
      },
      "required": ["id", "firstName", "lastName"]
    },
    "LibrarySession": {
      "title": "LibrarySession",
      "type": "object",
      "description": "Records a library visit session.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "checkInTime": { "type": "string", "format": "date-time" },
        "checkOutTime": { "type": "string", "format": "date-time" },
        "purpose": { "type": "string", "enum": ["Reading Books", "Thesis Research", "Computer Use", "Assignments", "Others"] },
        "visitorName": { "type": "string" },
        "collegeOrOffice": { "type": "string" }
      },
      "required": ["id", "studentId", "checkInTime", "purpose"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Visitor profiles."
    },
    "/librarySessions/{sessionId}": {
      "schema": "LibrarySession",
      "description": "Check-in/out records."
    }
  }
}
